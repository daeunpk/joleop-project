DATABASE_URL=postgresql+asyncpg://lion:lion_password@localhost:5432/lion

# anthropic 또는 ollama
LLM_PROVIDER=ollama
ANTHROPIC_API_KEY=

# LLM_PROVIDER=ollama 로 바꿀 때 사용
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
STORY_MODEL=llama3.1:8b
STORY_JUDGE_MODELS=qwen2.5:7b

HF_TOKEN=
ELEVENLABS_API_KEY=

# none이면 이미지 파일은 만들지 않고 image_prompt/image_path만 저장
# comfyui이면 로컬 ComfyUI API로 실제 이미지를 생성
IMAGE_PROVIDER=comfyui
IMAGE_OUTPUT_DIR=images
IMAGE_REFERENCE=
COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_CHECKPOINT=sd_xl_base_1.0.safetensors
COMFYUI_WIDTH=832
COMFYUI_HEIGHT=1216
COMFYUI_STEPS=28
COMFYUI_CFG=7.0
COMFYUI_SAMPLER=euler
COMFYUI_SCHEDULER=normal
